<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:id="@+id/txtTitulo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Lista de Carreras"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#111827"
            android:gravity="center"
            android:layout_marginTop="50dp"
            android:layout_marginBottom="30dp"/>

        <ListView
            android:id="@+id/listCarreras"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:divider="@android:color/transparent"
            android:dividerHeight="10dp"/>

    </LinearLayout>

    <!-- FOOTER -->
    <LinearLayout
        android:id="@+id/footer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#111827"
        android:padding="20dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Desarrollado por:"
            android:textColor="@android:color/white"
            android:textStyle="bold"
            android:textSize="14sp"
            android:gravity="center"
            android:paddingBottom="8dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Jonás García Corniel – 1-18-4259\nAdonis Rodríguez – 117-4399\nEuris Joel Acosta – 1-19-3584\nGabriel Hernández Galván – 2-21-3988\nErik Miguel Gil Cruz – 1-22-5249"
            android:textColor="#E5E7EB"
            android:textSize="13sp"
            android:gravity="center"
            android:lineSpacingExtra="4dp"/>

    </LinearLayout>

</LinearLayout>